is_global = true

# Global analyzer config for the WolfCurses repository (discovered automatically by the SDK;
# do NOT also reference it via a GlobalAnalyzerConfigFiles item, or the duplicate entries cancel out).
# Meziantou.Analyzer supplies exactly two rules here: MA0048 (file name must match type name, which
# also forces one type per file) and MA0137 (Async suffix for awaitable-returning methods; the
# .editorconfig naming rule only sees methods declared with the async modifier). Every other MA rule
# is explicitly disabled below; IDs that do not exist in the referenced analyzer version are ignored
# harmlessly, so the range is generous on purpose.
dotnet_diagnostic.MA0048.severity = warning
dotnet_diagnostic.MA0137.severity = warning
dotnet_diagnostic.MA0001.severity = none
